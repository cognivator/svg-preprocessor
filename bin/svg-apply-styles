#!/usr/bin/env node

const fs = require('fs');
const { JSDOM } = require('jsdom');

function extractVariablesFromCSS(cssText) {
  const variables = {};
  // Extract CSS variable definitions using regex
  const varRegex = /(--[a-zA-Z0-9-_]+)\s*:\s*([^;}]+)/g;
  let match;
  
  while ((match = varRegex.exec(cssText)) !== null) {
    const varName = match[1].substring(2); // Remove --
    const value = match[2].trim();
    variables[varName] = value;
  }
  
  return variables;
}

function resolveVariableToLiteral(varName, variables, visited = new Set()) {
  // Prevent infinite recursion
  if (visited.has(varName)) {
    return null;
  }
  visited.add(varName);
  
  const value = variables[varName];
  if (!value) {
    return null;
  }
  
  // Check if value is a var() reference
  const varMatch = value.match(/var\s*\(\s*--([^,)]+)(?:\s*,\s*([^)]*))?\s*\)/);
  if (varMatch) {
    const referencedVar = varMatch[1].trim();
    const fallback = varMatch[2] ? varMatch[2].trim() : null;
    
    // Recursively resolve the referenced variable
    const resolvedValue = resolveVariableToLiteral(referencedVar, variables, visited);
    return resolvedValue || fallback || null;
  }
  
  // It's already a literal value
  return value;
}

function resolveVarReference(value, variables) {
  const varMatch = value.match(/var\s*\(\s*--([^,)]+)(?:\s*,\s*([^)]*))?\s*\)/);
  if (varMatch) {
    const varName = varMatch[1].trim();
    const fallback = varMatch[2] ? varMatch[2].trim() : null;
    
    // Resolve the variable to its final literal value
    const resolvedValue = resolveVariableToLiteral(varName, variables);
    return resolvedValue || fallback || null;
  }
  return null;
}

function replaceVarsInStyle(styleValue, variables) {
  return styleValue.replace(/var\s*\(\s*--([^,)]+)(?:\s*,\s*([^)]*))?\s*\)/g, (match, varName, fallback) => {
    const resolvedValue = resolveVariableToLiteral(varName.trim(), variables);
    return resolvedValue || (fallback ? fallback.trim() : match);
  });
}

function applyStyles(svgContent) {
  const dom = new JSDOM(svgContent, { contentType: 'image/svg+xml' });
  const document = dom.window.document;
  const svgElement = document.querySelector('svg');
  
  if (!svgElement) throw new Error('No SVG element found');
  
  // Extract variables from all style elements
  const styleElements = document.querySelectorAll('style');
  let allVariables = {};
  
  styleElements.forEach(styleElement => {
    const cssText = styleElement.textContent;
    if (cssText.trim()) {
      const variables = extractVariablesFromCSS(cssText);
      allVariables = { ...allVariables, ...variables };
    }
  });
  
  // Apply variables to SVG attributes (but don't modify <style> content)
  document.querySelectorAll('*').forEach(element => {
    // Process fill/stroke attributes with var() references
    ['fill', 'stroke'].forEach(attr => {
      const value = element.getAttribute(attr);
      if (value && value.includes('var(')) {
        const resolved = resolveVarReference(value, allVariables);
        if (resolved) {
          element.setAttribute(attr, resolved);
        }
      }
    });
    
    // Process style attributes
    const style = element.getAttribute('style');
    if (style && style.includes('var(')) {
      const resolvedStyle = replaceVarsInStyle(style, allVariables);
      element.setAttribute('style', resolvedStyle);
    }
    
    // Process class-based styling
    const className = element.getAttribute('class');
    if (className) {
      const possibleVars = [className, className.replace('-', '_')];
      for (const varName of possibleVars) {
        const resolvedValue = resolveVariableToLiteral(varName, allVariables);
        if (resolvedValue) {
          element.setAttribute('fill', resolvedValue);
          break;
        }
      }
    }
  });
  
  return dom.serialize();
}

const inputFile = process.argv[2];
if (inputFile && inputFile !== '-') {
  try {
    process.stdout.write(applyStyles(fs.readFileSync(inputFile, 'utf8')));
  } catch (error) {
    console.error('Error:', error.message);
    process.exit(1);
  }
} else {
  let input = '';
  process.stdin.setEncoding('utf8');
  process.stdin.on('data', chunk => input += chunk);
  process.stdin.on('end', () => {
    try {
      process.stdout.write(applyStyles(input));
    } catch (error) {
      console.error('Error:', error.message);
      process.exit(1);
    }
  });
}
