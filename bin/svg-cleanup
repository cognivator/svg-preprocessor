#!/usr/bin/env node

const fs = require('fs');
const { JSDOM } = require('jsdom');

function cleanup(svgContent) {
  const dom = new JSDOM(svgContent, { contentType: 'image/svg+xml' });
  const document = dom.window.document;
  const svgElement = document.querySelector('svg');
  
  if (!svgElement) throw new Error('No SVG element found');
  
  // Remove style elements
  document.querySelectorAll('style').forEach(style => style.remove());
  
  // Remove CSS class attributes used for styling
  document.querySelectorAll('*[class]').forEach(element => {
    const className = element.getAttribute('class');
    if (className && className.match(/^(palette|theme|brand)-/)) {
      element.removeAttribute('class');
    }
  });
  
  return dom.serialize();
}

const inputFile = process.argv[2];
if (inputFile && inputFile !== '-') {
  try {
    process.stdout.write(cleanup(fs.readFileSync(inputFile, 'utf8')));
  } catch (error) {
    console.error('Error:', error.message);
    process.exit(1);
  }
} else {
  let input = '';
  process.stdin.setEncoding('utf8');
  process.stdin.on('data', chunk => input += chunk);
  process.stdin.on('end', () => {
    try {
      process.stdout.write(cleanup(input));
    } catch (error) {
      console.error('Error:', error.message);
      process.exit(1);
    }
  });
}