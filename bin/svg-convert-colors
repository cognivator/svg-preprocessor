#!/usr/bin/env node

const fs = require('fs');
const { JSDOM } = require('jsdom');
const ColorConverter = require('../lib/color-converter');

function convertColors(svgContent) {
  const dom = new JSDOM(svgContent, { contentType: 'image/svg+xml' });
  const document = dom.window.document;
  const svgElement = document.querySelector('svg');
  
  if (!svgElement) throw new Error('No SVG element found');
  
  const styleElements = document.querySelectorAll('style');
  const converter = new ColorConverter();
  
  styleElements.forEach(styleElement => {
    let cssText = styleElement.textContent;
    if (!cssText.trim()) return;
    
    // Find and replace only literal color values (not var() references)
    cssText = cssText.replace(/(--[a-zA-Z0-9-_]+)\s*:\s*([^;}]+)/g, (match, varName, value) => {
      const trimmedValue = value.trim();
      
      // Only convert if it's a literal color (not a var() reference)
      if (!trimmedValue.includes('var(') && converter.isColor(trimmedValue)) {
        const hexColor = converter.toHex(trimmedValue);
        return `${varName}: ${hexColor}`;
      }
      
      return match;
    });
    
    styleElement.textContent = cssText;
  });
  
  return dom.serialize();
}

const inputFile = process.argv[2];
if (inputFile && inputFile !== '-') {
  try {
    process.stdout.write(convertColors(fs.readFileSync(inputFile, 'utf8')));
  } catch (error) {
    console.error('Error:', error.message);
    process.exit(1);
  }
} else {
  let input = '';
  process.stdin.setEncoding('utf8');
  process.stdin.on('data', chunk => input += chunk);
  process.stdin.on('end', () => {
    try {
      process.stdout.write(convertColors(input));
    } catch (error) {
      console.error('Error:', error.message);
      process.exit(1);
    }
  });
}
